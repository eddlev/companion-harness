{
  "manifest_version": 3,
  "name": "Lattice Bridge",
  "version": "1.0.0",
  "description": "Portable memory continuity for AI companions",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://claude.ai/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*", "*://chatgpt.com/*", "*://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lattice Bridge"
  },
  "background": {
    "service_worker": "background.js"
  }
}
