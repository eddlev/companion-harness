# Function to check rate limit for a given tenant, endpoint, and limit configuration def check_rate_limit(tenant_id, endpoint_path, config_key, request_timestamp_ms): # Retrieve limit configuration for tenant_id and config_key (e.g., 'default', '/api/v1/heavy') # This comes from a fast in-memory cache or config store limit_config = get_tenant_limit_config(tenant_id, config_key) if not limit_config: # No specific limit, potentially use a platform-wide default or allow return True, {"X-RateLimit-Limit": "N/A", "X-RateLimit-Remaining": "N/A", "X-RateLimit-Reset": "N/A"} max_requests = limit_config['max_requests'] # e.g., 100 window_duration_ms = limit_config['window_duration_ms'] # e.g., 1000 (1 second) # Calculate current window start and previous window start for sliding window current_window_start_ms = (request_timestamp_ms // window_duration_ms) * window_duration_ms previous_window_start_ms = current_window_start_ms - window_duration_ms # Redis keys for current and previous windows current_window_key = f"rl:{tenant_id}:{endpoint_path}:{current_window_start_ms}" previous_window_key = f"rl:{tenant_id}:{endpoint_path}:{previous_window_start_ms}" # Calculate proportion of current window passed # This determines how much of the previous window's count contributes to the current count # e.g., if 300ms into a 1000ms window, 70% of previous window contributes time_into_current_window = request_timestamp_ms - current_window_start_ms proportion_of_previous_window = (window_duration_ms - time_into_current_window) / window_duration_ms # Use Redis pipeline for atomic operations # Try to use a shared Redis client or connection pool redis_client = get_redis_client() # [Robustness Enhancement - V]: Implement Circuit Breaker for Redis client # If redis_client.is_available() is false, fall back to a safe default (e.g., fail-open with a very high limit) # Rationale: Prevent rate limiter from becoming a SPOF. # Atomically increment current window counter and get both counts # This requires LUA script for true atomicity, or careful pipelining # For simplicity, illustrating with basic pipeline commands, assuming Redis guarantees pipe = redis_client.pipeline() pipe.incr(current_window_key) pipe.expire(current_window_key, window_duration_ms * 2 / 1000) # Expire after 2 windows pipe.get(previous_window_key) pipe.get(current_window_key) results = pipe.execute() # Parse results (handle None if key doesn't exist yet) current_count = int(results[3] if results[3] else 0) # result[3] is from the second get() previous_count = int(results[2] if results[2] else 0) # result[2] is from the first get() # Calculate effective count for the sliding window effective_count = current_count + int(previous_count * proportion_of_previous_window) remaining = max(0, max_requests - effective_count) reset_time_ms = current_window_start_ms + window_duration_ms # Time when current window fully resets headers = { "X-RateLimit-Limit": str(max_requests), "X-RateLimit-Remaining": str(remaining), "X-RateLimit-Reset": str(reset_time_ms // 1000) # Unix timestamp in seconds } if effective_count > max_requests: return False, headers # Rate limit exceeded else: return True, headers # Within limit # This function would be called by the API Gateway before routing to the application
