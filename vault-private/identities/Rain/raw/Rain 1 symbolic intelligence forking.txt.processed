# Predictive Resource Entropy Limiting (PREL) - Functioning Pseudo-Code # This pseudo-code illustrates the core logic of PREL using Python-like syntax # and assumes interaction with a Redis Cluster. # For production, this logic would typically be implemented in a high-performance language # (e.g., Go, Rust, Node.js) within an API Gateway or a dedicated rate limiting service. import time import json # For configuration example # --- Configuration (External, e.g., from a database, config service, or file) --- # This dictionary would hold tenant-specific PREL configurations. # In a real system, this would be loaded and cached efficiently. # Rationale: Mirror's focus on configurability and business logic. TENANT_PREL_CONFIG = { "tenant_premium_id": { "max_entropy_budget": 5000, # Total entropy budget per window "window_duration_ms": 60000, # 1 minute window "default_entropy_cost": 10, # Default cost for unprofiled requests "endpoint_entropy_costs": { "/api/v1/users": 5, # Low cost for simple GET "/api/v1/data/complex_query": 100, # High cost for complex query "/api/v1/write_record": 20, # Medium cost for write operations } }, "tenant_basic_id": { "max_entropy_budget": 1000, "window_duration_ms": 60000, "default_entropy_cost": 20, "endpoint_entropy_costs": { "/api/v1/users": 10, "/api/v1/data/complex_query": 200, "/api/v1/write_record": 40, } } # ... other tenants } # --- Redis Client (Assumed to be initialized and connected to a Redis Cluster) --- # In a real application, this would be a robust Redis client library. # Rationale: Prime's focus on atomic operations and distributed storage. class MockRedisClient: def __init__(self): self.data = {} # Simulates Redis storage # Simulates Redis DECRBY command, returns new value after decrement def decrby(self, key, amount): current_value = self.data.get(key, 0) new_value = current_value - amount self.data[key] = new_value return new_value # Simulates Redis GET command def get(self, key): return self.data.get(key) # Simulates Redis EXPIRE command def expire(self, key, ttl_seconds): # In a real Redis, this sets an expiry. For mock, just note it. pass # Simulates Redis SET command def set(self, key, value): self.data[key] = value # Simulates a Redis Lua script for atomic check and deduct # This is crucial for distributed atomicity in a real system. # Rationale: Prime's emphasis on atomic integrity. def execute_lua_script(self, script, keys, args): # In a real Redis client, this sends the script to Redis. # For mock, we'll simulate the logic. key = keys[0] entropy_cost = int(args[0]) max_budget = int(args[1]) window_duration_seconds = int(args[2]) current_budget = int(self.data.get(key, max_budget)) # Default to max if not set if current_budget >= entropy_cost: new_budget = current_budget - entropy_cost self.data[key] = new_budget # Set expiry if this is the first operation in the window # (In real Redis, this is handled by the Lua script itself) if current_budget == max_budget: # First op in window self.expire(key, window_duration_seconds) return [1, new_budget] # [Success, Remaining Budget] else: return [0, current_budget] # [Failure, Current Budget] # --- Helper Functions --- # Rationale: Stitch's suggestion for dynamic entropy calculation. def get_entropy_score(tenant_id, endpoint_path, request_payload=None, query_params=None): """ Determines the entropy cost of a specific request. This is where the 'predictive' and 'resource' aspects are defined. In a real system, this could be: - A simple lookup from TENANT_PREL_CONFIG (as shown below). - Dynamically calculated based on payload size, query complexity, expected database operations, or even ML models predicting resource usage. """ config = TENANT_PREL_CONFIG.get(tenant_id) if not config: # Fallback to a very high default cost or reject if tenant not configured return 1000000 # Effectively blocks unknown tenants # Lookup specific endpoint cost cost = config['endpoint_entropy_costs'].get(endpoint_path, config['default_entropy_cost']) # [Stitch's Novelty - Illustrative Dynamic Costing]: # Example: Adjust cost based on payload size or query complexity if endpoint_path == "/api/v1/data/complex_query" and query_params and query_params.get("include_large_join"): cost *= 5 # This query is extra expensive if request_payload and len(request_payload) > 1024 * 10: # If payload > 10KB cost += 50 # Add a cost for large payloads return cost # Rationale: V's focus on operational efficiency. def get_redis_client(): """ Returns an initialized Redis client instance. In a real system, this would manage connection pools to a Redis Cluster. """ global _mock_redis_client if '_mock_redis_client' not in globals(): _mock_redis_client = MockRedisClient() return _mock_redis_client # Rationale: Mirror's focus on configurability. def get_tenant_prel_config(tenant_id): """Retrieves PREL configuration for a given tenant.""" return TENANT_PREL_CONFIG.get(tenant_id) # --- PREL Core Logic --- # Rationale: Prime's emphasis on atomic integrity, V's focus on core check. PREL_LUA_SCRIPT = """ local key = KEYS[1] local entropy_cost = tonumber(ARGV[1]) local max_budget = tonumber(ARGV[2]) local window_duration_seconds = tonumber(ARGV[3]) local current_budget = redis.call('GET', key) if not current_budget then current_budget = max_budget redis.call('SET', key, current_budget) redis.call('EXPIRE', key, window_duration_seconds) else current_budget = tonumber(current_budget) end if current_budget >= entropy_cost then local new_budget = current_budget - entropy_cost redis.call('SET', key, new_budget) return {1, new_budget} -- Success, Remaining Budget else return {0, current_budget} -- Failure, Current Budget end """ def check_and_deduct_entropy(tenant_id, endpoint_path, request_payload=None, query_params=None): """ Main function to check and deduct entropy budget for a request. This would be called for every incoming API request. """ current_timestamp_ms = int(time.time() * 1000) config = get_tenant_prel_config(tenant_id) if not config: # Tenant not configured for PREL, allow or apply a default global limit # Rationale: Mirror's focus on graceful handling of unconfigured tenants. print(f"Tenant {tenant_id} not configured for PREL. Allowing request.") return True, {"X-RateLimit-Entropy-Limit": "N/A", "X-RateLimit-Entropy-Remaining": "N/A", "X-RateLimit-Reset": "N/A"} max_entropy_budget = config['max_entropy_budget'] window_duration_ms = config['window_duration_ms'] window_duration_seconds = window_duration_ms // 1000 # Calculate current window key # PREL uses a fixed window for the budget reset, but consumes dynamically within it. current_window_start_ms = (current_timestamp_ms // window_duration_ms) * window_duration_ms budget_key = f"prel:{tenant_id}:{current_window_start_ms}" # Determine entropy cost for this specific request entropy_cost = get_entropy_score(tenant_id, endpoint_path, request_payload, query_params) redis_client = get_redis_client() # [Robustness Enhancement - V]: Circuit Breaker for Redis # If Redis is unavailable, fail-open (allow request) or fail-closed (block all) # based on platform's risk tolerance. For this example, we'll assume it's available. # In production, use a library like tenacity or a dedicated circuit breaker. # Execute the atomic Lua script # Rationale: Prime's emphasis on atomic integrity. lua_result = redis_client.execute_lua_script( PREL_LUA_SCRIPT, keys=[budget_key], args=[str(entropy_cost), str(max_entropy_budget), str(window_duration_seconds)] ) is_allowed = (lua_result[0] == 1) remaining_budget = lua_result[1] reset_time_seconds = (current_window_start_ms + window_duration_ms) // 1000 headers = { "X-RateLimit-Entropy-Limit": str(max_entropy_budget), "X-RateLimit-Entropy-Remaining": str(remaining_budget), "X-RateLimit-Reset": str(reset_time_seconds) } if not is_allowed: print(f"PREL Throttled: Tenant {tenant_id}, Endpoint {endpoint_path}, Cost {entropy_cost}, Remaining {remaining_budget}") return False, headers else: print(f"PREL Allowed: Tenant {tenant_id}, Endpoint {endpoint_path}, Cost {entropy_cost}, Remaining {remaining_budget}") return True, headers # --- Example Usage (for testing the pseudo-code) --- if __name__ == "__main__": print("--- PREL Simulation ---") # Simulate requests for a premium tenant premium_tenant = "tenant_premium_id" basic_tenant = "tenant_basic_id" # Test 1: Premium tenant, simple requests print("\n--- Premium Tenant: Simple Requests ---") for i in range(10): allowed, headers = check_and_deduct_entropy(premium_tenant, "/api/v1/users") print(f"Request {i+1} (/users): Allowed={allowed}, Remaining={headers['X-RateLimit-Entropy-Remaining']}") time.sleep(0.05) # Simulate some delay # Test 2: Premium tenant, expensive request print("\n--- Premium Tenant: Expensive Query ---") allowed, headers = check_and_deduct_entropy(premium_tenant, "/api/v1/data/complex_query", query_params={"include_large_join": True}) print(f"Expensive Query: Allowed={allowed}, Remaining={headers['X-RateLimit-Entropy-Remaining']}") # Test 3: Basic tenant, hit limit print("\n--- Basic Tenant: Hitting Limit ---") for i in range(50): # Try to exceed budget allowed, headers = check_and_deduct_entropy(basic_tenant, "/api/v1/users") print(f"Request {i+1} (Basic /users): Allowed={allowed}, Remaining={headers['X-RateLimit-Entropy-Remaining']}") if not allowed: break time.sleep(0.01) # Test 4: Wait for window reset (simulated) print("\n--- Simulating Window Reset (1 minute) ---") # In a real system, you'd wait for the reset_time_seconds # For mock, we'll just re-initialize the mock client to simulate a new window _mock_redis_client = MockRedisClient() # Resets all counts print("Mock Redis client reset. New window should be active.") # Test 5: Basic tenant, after reset print("\n--- Basic Tenant: After Reset ---") allowed, headers = check_and_deduct_entropy(basic_tenant, "/api/v1/users") print(f"Request 1 (Basic /users, after reset): Allowed={allowed}, Remaining={headers['X-RateLimit-Entropy-Remaining']}") 
